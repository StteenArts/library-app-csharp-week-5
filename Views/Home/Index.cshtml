@{
    ViewData["Title"] = "Home Page";
}
@model activity_w5_library.viewModels.DashboardViewModel

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h3 class="text-light">Hola! Santi</h3>
    <p class="text-body-emphasis fw-bold">Bienvenido a tu panel de administración</p>
  </div>
  <!-- Button to trigger close session user-->
  <a asp-action="Index" asp-controller="Login" class="btn btn-outline-danger d-flex align-items-center gap-2 px-4 py-2 shadow-sm">
    <i class="bi bi-door-open-fill"></i>
    <span class="fw-bold">Cerrar Sesión</span>
  </a>

  
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
  
  <!-- Usuarios -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Total Usuarios</div>
        <div class="card-value">1,284</div>
      </div>
      <div class="icon-box bg-blue-soft"><i class="bi bi-people-fill"></i></div>
    </div>
  </div>

  <!-- Libros -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Total Libros</div>
        <div class="card-value">3,567</div>
      </div>
      <div class="icon-box bg-purple-soft"><i class="bi bi-journal-bookmark-fill"></i></div>
    </div>
  </div>

  <!-- Préstamos -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Préstamos Activos</div>
        <div class="card-value">89</div>
      </div>
      <div class="icon-box bg-green-soft"><i class="bi bi-wallet"></i></div>
    </div>
  </div>

  <!-- Registros -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Nuevos Registros</div>
        <div class="card-value">156</div>
      </div>
      <div class="icon-box bg-orange-soft"><i class="bi bi-bookmark-plus-fill"></i></div>
    </div>
  </div>

</div>

<!-- Charts -->
<div class="row g-3 mb-4">

  <div class="col-md-8">
    <div class="card card-dark p-3">
      <h4 class="fw-bold">Actividad de Préstamos</h4>
      <div class="chart-box mt-3 d-flex align-items-center justify-content-center">
        (Aquí poner Chart.js)
      </div>
    </div>
  </div>
  
  <!-- Actions Quickly -->
  <div class="col-md-4">
    <div class="card bg-dark text-light border-secondary p-3 rounded-4 shadow-sm">

      <!-- Title -->
      <h5 class="fw-bold mb-3">Acciones Rápidas</h5>

      <!-- Grid -->
      <div class="row g-2">

        <!-- Item 1 -->
        
        <div class="col-6">
          <button type="button"
                  class="w-100 border-0 bg-transparent p-0"
                  data-bs-toggle="modal"
                  data-bs-target="#modalCreateBook">

            <div class="card bg-black text-light text-center p-4 h-100 stats-card">
              <i class="bi bi-book fs-3 text-success iconStyle"></i>
              <small>Crear Libro</small>
            </div>

          </button>
        </div>
        
        <!-- Item 2 -->
        <div class="col-6">
          <button type="button"
                  class="w-100 border-0 bg-transparent p-0"
                  data-bs-toggle="modal"
                  data-bs-target="#modalCreateUser">

            <div class="card bg-black text-light text-center p-4 stats-card">
              <i class="bi bi-person-fill-add fs-3 text-info iconStyle"></i>
              <small>Crear Usuario</small>
            </div>

          </button>
        </div>
        


        <!-- Item 3 -->
        <div class="col-6">
          <div class="card bg-black text-light text-center p-4 h-100 stats-card">
            <i class="bi bi-gear fs-3 text-warning iconStyle"></i>
            <small>Configuraciones</small>
          </div>
        </div>
        
        <!-- Item 4 -->
        <div class="col-6">
          <button type="button"
                  class="w-100 border-0 bg-transparent p-0"
                  data-bs-toggle="modal"
                  data-bs-target="#modalCreateLoan">

            <div class="card bg-black text-light text-center p-4 stats-card">
              <i class="bi bi-bookmarks-fill fs-3 text-info iconStyle"></i>
              <small>Crear Prestamo</small>
            </div>

          </button>
        </div>
        

      </div>

    </div>
  </div>
<!-- Here finished the stats quick actions-->
</div>

<!-- Table of users stat dashboard -->
<div class="row g-3">

  <div class="col-md-8">
    <div class="card bg-dark text-light border-secondary p-3 rounded-4 shadow-sm">

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold">Usuarios</h5>
        <input class="form-control form-control-sm w-25 bg-secondary text-light border-0" placeholder="Buscar...">
      </div>

      <!-- Table -->
      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0" style="cursor:pointer;">

          <thead class="table-secondary text-dark">
          <tr>
            <th>Nombre</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
          </thead>

          <tbody>
          @if (Model.Users.Count > 0)
          {
            @foreach (var user in Model.Users)
            {
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-primary rounded-circle p-2">MG</span>
                    @user.Name
                  </div>
                </td>
                <td class="text-secondary small">@user.Email</td>
                <td><span class="badge bg-info text-dark">@user.Role</span></td>
                <td><span class="badge bg-success">@user.Status</span></td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-info"><i class="bi bi-eyeglasses"></i></button>
                  <button class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil-square"></i></button>
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash-fill"></i></button>
                </td>
              </tr>
            }
          }
          else
          {
            <tr class="text-center">
              <td colspan="12">Sin registros aún</td>
            </tr>
          }

          </tbody>

        </table>
      </div>

    </div>
  </div>

  <div class="col-md-4">
    <div class="card card-dark p-3">
      <!-- Header -->
      <div class="card-header bg-dark border-secondary mb-2 rounded-5">
        <h5 class="mb-0 text-light text-center">Libros</h5>
      </div>

      <!-- Table -->
      <div class="table-responsive ">
        <table class="table table-dark table-hover align-middle mb-0 text-center">

          <thead class="table-secondary text-dark">
          <tr>
            <th>Libro</th>
            <th>Status</th>
            <th>Acciones</th>
          </tr>
          </thead>

          <tbody class="table-dark" style="cursor:pointer;">
          @if (Model.Books.Count > 0)
          {
            @foreach (var book in Model.Books)
            {
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-primary rounded">@book.Title</span>
                  </div>
                </td>
                <td><span class="badge bg-success text-light">@book.Status</span></td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-info"><i class="bi bi-eyeglasses"></i></button>
                  <button class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil-square"></i></button>
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash-fill"></i></button>
                  
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="12">Sin registros aún</td>
            </tr>
          }
          </tbody>

        </table>
      </div>

    </div>
  </div>

</div>

<!-- Modal to create users -->
<div class="modal fade" data-bs-backdrop="static" id="modalCreateUser" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content modal-dark">

      <!-- Header -->
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">
          <i class="bi bi-person-plus-fill me-2 text-success"></i>
          Crear Usuario
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      
      <form>
        <!-- Body -->
        <div class="modal-body">
          <div class="row g-3">

            <!-- Name -->
            <div class="col-md-6">
              <label class="form-label text-light">Nombre</label>
              <input type="text" class="form-control input-dark" placeholder="Ej: Juan Pérez">
            </div>

            <!-- Email -->
            <div class="col-md-6">
              <label class="form-label text-light">Email</label>
              <input type="email" class="form-control input-dark" placeholder="correo@email.com">
            </div>

            <!-- Password -->
            <div class="col-md-6">
              <label class="form-label text-light">Contraseña</label>
              <input type="password" class="form-control input-dark" placeholder="********">
            </div>

            <!-- Rol -->
            <div class="col-md-6">
              <label class="form-label text-light">Rol</label>
              <select class="form-select input-dark">
                <option selected disabled>Seleccionar rol</option>
                <option>Admin</option>
                <option>User</option>
              </select>
            </div>

            <!-- Status -->
            <div class="col-12">
              <label class="form-label text-light">Estado</label>
              <select class="form-select input-dark">
                <option selected>Activo</option>
                <option>Pendiente</option>
                <option>Bloqueado</option>
              </select>
            </div>

          </div>
        </div>

        <!-- Footer -->
        <div class="modal-footer border-0 d-flex justify-content-between">
          <button class="btn btn-outline-danger px-4" data-bs-dismiss="modal">
            Cancelar
          </button>

          <button class="btn btn-success px-4 shadow" type="submit">
            <i class="bi bi-check-circle me-2"></i>
            Crear Usuario
          </button>
        </div>
        
      </form>
    </div>
  </div>
</div>


<!-- Modal to create books -->
<div class="modal fade" data-bs-backdrop="static" id="modalCreateBook" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content modal-dark">

      <!-- Header -->
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">
          <i class="bi bi-person-plus-fill me-2 text-success"></i>
          Crear Libro
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      
      <form>
        <!-- Body modal -->
        <div class="modal-body">
          <div class="row g-3">

            <!-- Name -->
            <div class="col-md-6">
              <label class="form-label text-light" for="title">Titulo</label>
              <input type="text" class="form-control input-dark" placeholder="Ej: Juan Pérez" name="title">
            </div>
            
            <!-- Author -->
            <div class="col-md-6">
              <label class="form-label text-light" for="author">Author</label>
              <input type="text" class="form-control input-dark" placeholder="Ej: Jose Hernandez" name="author">
            </div>
            
          </div>
        </div>

        <!-- Footer -->
        <div class="modal-footer border-0 d-flex justify-content-between">
          <button class="btn btn-outline-danger px-4" data-bs-dismiss="modal">
            Cancelar
          </button>

          <button class="btn btn-success px-4 shadow" type="submit">
            <i class="bi bi-check-circle me-2"></i>
            Crear Libro
          </button>
        </div>
        
      </form>
    </div>
  </div>
</div>


<!-- Modal to create loans -->
<div class="modal fade" data-bs-backdrop="static" id="modalCreateLoan" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content modal-dark">

      <!-- Header -->
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">
          <i class="bi bi-person-plus-fill me-2 text-success"></i>
          Crear Prestamo
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      
      <form>
        <!-- Body modal -->
        <div class="modal-body">
          <div class="row g-3">

            <!-- Name -->
            <div class="col-md-6">
              <label class="form-label text-light" for="book_id">Libro</label>
              <input type="text" class="form-control input-dark"  name="book_id">
            </div>
            
            <!-- Author -->
            <div class="col-md-6">
              <label class="form-label text-light" for="user_id">Usuario</label>
              <input type="text" class="form-control input-dark"  name="user_id">
            </div>
            
          </div>
        </div>

        <!-- Footer -->
        <div class="modal-footer border-0 d-flex justify-content-between">
          <button class="btn btn-outline-danger px-4" data-bs-dismiss="modal">
            Cancelar
          </button>

          <button class="btn btn-success px-4 shadow" type="submit">
            <i class="bi bi-check-circle me-2"></i>
            Crear Prestamo
          </button>
        </div>
        
      </form>
    </div>
  </div>
</div>