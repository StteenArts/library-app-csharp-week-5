            </td>
          </tr>

          </tbody>

        </table>
      </div>

    </div>
  </div>

  <div class="col-md-4">
    <div class="card card-dark p-3">
      <!-- Header -->
      <div class="card-header bg-dark border-secondary mb-2 rounded-5">
        <h6 class="mb-0 text-light">Libros Más Prestados</h6>
      </div>

      <!-- Table -->
      <div class="table-responsive ">
        <table class="table table-dark table-hover align-middle mb-0">

          <thead class="table-secondary text-dark">
          <tr>
            <th>#</th>
            <th>Libro</th>
            <th>Autor</th>
            <th class="text-end">Préstamos</th>
          </tr>
          </thead>

          <tbody class="table-dark" style="cursor:pointer;">

          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="badge bg-primary rounded">2</span>
              </div>
            </td>
            <td class="text-light small">Don Quijote</td>
            <td><span class="badge bg-info text-dark">Miguel de Cervantes</span></td>
            <td class="text-end">
              <span class="badge bg-primary rounded-pill">142</span>
            </td>
          </tr>
          
          <tr>
            <td>
              <div class="d-flex align-items-center gap-2">
                <span class="badge bg-primary rounded">3</span>
              </div>
            </td>
            <td class="text-light small">1984</td>
            <td><span class="badge bg-info text-dark">George Orwell</span></td>
            <td class="text-end">
              <span class="badge bg-primary rounded-pill">128</span>
            </td>
          </tr>
          

          </tbody>

        </table>
      </div>

    </div>
  </div>

</div>


<!-- Modal to register new record (Usuarios)-->
<div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        ...
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary">Save changes</button>
      </div>
    </div>
  </div>
</div>