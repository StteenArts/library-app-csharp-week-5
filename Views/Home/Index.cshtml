@{
    ViewData["Title"] = "Home Page";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h3 class="text-light">Hola! Santi</h3>
    <p class="text-body-emphasis fw-bold">Bienvenido a tu panel de administración</p>
  </div>
  <button class="btn btn-outline-success d-flex align-items-center gap-2 px-4 py-2 shadow-sm" data-toggle="modal" data-target="#createModal">
    <i class="bi bi-plus-circle-fill text-light"></i>
    <span class="fw-bold text-light">Crear Registro</span>
  </button>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
  
  <!-- Usuarios -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Total Usuarios</div>
        <div class="card-value">1,284</div>
      </div>
      <div class="icon-box bg-blue-soft"><i class="bi bi-people-fill"></i></div>
    </div>
  </div>

  <!-- Libros -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Total Libros</div>
        <div class="card-value">3,567</div>
      </div>
      <div class="icon-box bg-purple-soft"><i class="bi bi-journal-bookmark-fill"></i></div>
    </div>
  </div>

  <!-- Préstamos -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Préstamos Activos</div>
        <div class="card-value">89</div>
      </div>
      <div class="icon-box bg-green-soft"><i class="bi bi-wallet"></i></div>
    </div>
  </div>

  <!-- Registros -->
  <div class="col-md-3">
    <div class="card-dark d-flex justify-content-between align-items-center">
      <div>
        <div class="card-title">Nuevos Registros</div>
        <div class="card-value">156</div>
      </div>
      <div class="icon-box bg-orange-soft"><i class="bi bi-bookmark-plus-fill"></i></div>
    </div>
  </div>

</div>

<!-- Charts -->
<div class="row g-3 mb-4">

  <div class="col-md-8">
    <div class="card card-dark p-3">
      <h4 class="fw-bold">Actividad de Préstamos</h4>
      <div class="chart-box mt-3 d-flex align-items-center justify-content-center">
        (Aquí poner Chart.js)
      </div>
    </div>
  </div>
  
  <!-- Actions Quickly -->
  <div class="col-md-4">
    <div class="card bg-dark text-light border-secondary p-3 rounded-4 shadow-sm">

      <!-- Title -->
      <h5 class="fw-bold mb-3">Acciones Rápidas</h5>

      <!-- Grid -->
      <div class="row g-2">

        <!-- Item 1 -->
        <div class="col-6">
          <div class="card bg-black text-light text-center p-4 h-100 stats-card ">
            <i class="bi bi-book fs-3 text-success iconStyle"></i>
            <small>Crear Libro</small>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="col-6">
          <div class="card bg-black text-light text-center p-4 stats-card">
            <i class="bi bi-person-fill-add fs-3 text-info iconStyle"></i>
            <small>Crear Usuario</small>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="col-6">
          <div class="card bg-black text-light text-center p-4 h-100 stats-card">
            <i class="bi bi-gear fs-3 text-warning iconStyle"></i>
            <small>Configuraciones</small>
          </div>
        </div>

        <!-- Item 4 -->
        <div class="col-6">
          <div class="card bg-black text-light text-center p-4 h-100 stats-card">
            <i class="bi bi-upc-scan fs-3 text-primary iconStyle"></i>
            <small>Prestamos</small>
          </div>
        </div>
        

      </div>

    </div>
  </div>
<!-- Here finished the stats quick actions-->
</div>

<!-- Table of users stat dashboard -->
<div class="row g-3">

  <div class="col-md-8">
    <div class="card bg-dark text-light border-secondary p-3 rounded-4 shadow-sm">

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold">Usuarios</h5>
        <input class="form-control form-control-sm w-25 bg-secondary text-light border-0" placeholder="Buscar...">
      </div>

      <!-- Table -->
      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0" style="cursor:pointer;">

          <thead class="table-secondary text-dark">
